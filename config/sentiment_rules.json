{
  "Version": "1.1",
  "Description": "Sentiment and resolution vocabulary for the EIP pipeline. Used by Step 3 (Semantic Extraction) Get-TopicSentiment to classify topic sentiment. Version 1.1 adds negation handling, severity tiers, neutral/in-progress state, and NPI/compliance domain vocabulary.",
  "Changelog": [
    {
      "version": "1.1",
      "date": "2026-07-01",
      "changes": [
        "Added NegationPrefixes for negation window handling in Get-TopicSentiment",
        "Negative restructured into Critical and Warning severity tiers",
        "Added Neutral list for in-progress / ambiguous state terms",
        "Added NpiVocabulary for NPI-phase domain terms",
        "Added ComplianceVocabulary for regulatory/certification domain terms",
        "Added SupplierVocabulary for supply chain / OEM context terms",
        "ResolutionPriority retained from v1.0"
      ]
    },
    {
      "version": "1.0",
      "date": "2026-01-01",
      "changes": ["Initial version — flat Positive / Negative / ResolutionPriority lists"]
    }
  ],
  "NegationPrefixes": [
