  "SemanticIntegrityRules": [
    {
      "id": "ProductBrandResolution",
      "description": "Ensure product mentions are attributed to the correct brand. C-Pen, SuperPen, e-pens, and Wizcom are distinct products — conflating them in a summary is a semantic error.",
      "trigger_keywords": ["C-Pen", "SuperPen", "e-pens", "Wizcom", "scanning pen", "EP-XP-S2"],
      "validation": "When multiple brand names appear in the same segment, verify the context applies equally to all brands or flag as BRAND_CAST_CONFLICT",
      "conflict_type": "BrandCastConflict",
      "severity": "warning",
      "suppress_keywords": ["banking", "funding", "overdraft", "account", "payment", "revenue", "cash flow"]
    },
    {
      "id": "SupplierBrandConflict",
      "description": "Supplier-side mentions (Hanwang, e-pens OEM, EP-XP-S2) must not be attributed to C-Pen engineering or Wizcom. Hanwang manufactures C-Pen hardware (ODM); e-pens OEM is a separate supply relationship.",
      "trigger_keywords": ["Hanwang", "e-pens OEM", "EP-XP-S2", "OEM", "factory", "offline language pack", "pre-install"],
      "validation": "Contributions in this context should be attributed to Supply Chain / Operations, not to Wizcom engineering or C-Pen product team",
      "conflict_type": "SupplierBrandConflict",
      "severity": "warning",
      "suppress_keywords": ["NPI", "Roadmap", "Sprint", "Backlog", "User Story"]
    },
    {
      "id": "PersonBrandConflict",
      "description": "Wizcom engineers have brand_exclusions for C-Pen and e-pens. If a Wizcom engineer is attributed to a C-Pen or e-pens decision, flag as a potential brand attribution error.",
      "trigger_people_org": "org_wizcom",
      "excluded_brands": ["C-Pen", "e-pens"],
      "validation": "Check whether the contribution genuinely relates to Wizcom/SuperPen or has been incorrectly attributed to a cross-brand topic",
      "conflict_type": "PersonBrandConflict",
      "severity": "warning"
    },
    {
      "id": "BrandCastConflict",
