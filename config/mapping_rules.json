{
  "Version": "2.2",
  "Description": "Topic keyword mapping rules for the EIP pipeline. Used by Step 3 (Semantic Extraction) to match transcript segments to taxonomy topics. Version 2.2 adds context_bias per topic for meeting-context-aware scoring, NpiContextGuard semantic integrity rule, product-component vocabulary in T01/T07, and strengthened suppress_keywords on T18 to prevent product-UI terms bleeding into executive reporting topics.",
  "Changelog": [
    {
      "version": "2.2",
      "date": "2026-07-21",
      "changes": [
        "Added context_bias blocks to all 18 topic rules — boost_in / suppress_in execution context lists",
        "Added NpiContextGuard to SemanticIntegrityRules — meeting-type-based topic demotion/promotion for NPI and Product Development meetings",
        "Added product-component vocabulary to T01 (Product Performance): dashboard, home screen, menu, UI element, navigation screen, settings screen, widget, app screen",
        "Added product-component vocabulary to T07 (Development Execution): dashboard, admin panel, product UI, SuperPen UI, app interface",
        "Added suppress_keywords to T18 (Delivery Confidence) to prevent product-UI terms (dashboard, home screen, UI, widget, component, feature, NPI) triggering executive reporting match",
        "Context scoring: NPI-managed and Product Development contexts boost CPO-domain topics (T01,T02,T04,T05,T06,T07) and suppress CEO-domain topics (T15,T18)"
      ]
    },
    {
      "version": "2.1",
      "date": "2026-07-01",
      "changes": [
        "Comprehensive keyword expansion for all 18 topics (T01–T18)",
        "suppress_keywords added per topic to reduce false-positive matches",
        "SemanticIntegrityRules added: ProductBrandResolution, SupplierBrandConflict, PersonBrandConflict, BrandCastConflict",
        "e-pens product vocabulary added (EP-XP-S2, offline language packs, pre-install, OEM)",
        "NPI phase vocabulary integrated into T05 and T07",
        "Brand-scoped keyword sets added for C-Pen, SuperPen, Wizcom, e-pens disambiguation"
      ]
    },
    {
      "version": "2.0",
      "date": "2026-01-01",
      "changes": ["Initial version — minimal keyword sets"]
    }
  ],

