  "Version": "2.1",
  "Description": "Topic keyword mapping rules for the EIP pipeline. Used by Step 3 (Semantic Extraction) to match transcript segments to taxonomy topics. Version 2.1 adds comprehensive keyword expansion for all 18 topics, suppress_keywords for noise reduction, semantic integrity rules for brand conflict detection, and e-pens / product-specific vocabulary.",
  "Changelog": [
    {
      "version": "2.1",
      "date": "2026-07-01",
      "changes": [
        "Comprehensive keyword expansion for all 18 topics (T01–T18)",
        "suppress_keywords added per topic to reduce false-positive matches",
        "SemanticIntegrityRules added: ProductBrandResolution, SupplierBrandConflict, PersonBrandConflict, BrandCastConflict",
        "e-pens product vocabulary added (EP-XP-S2, offline language packs, pre-install, OEM)",
        "NPI phase vocabulary integrated into T05 and T07",
        "Brand-scoped keyword sets added for C-Pen, SuperPen, Wizcom, e-pens disambiguation"
      ]
    },
    {
      "version": "2.0",
      "date": "2026-01-01",
